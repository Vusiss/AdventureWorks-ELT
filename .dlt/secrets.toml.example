# Credentials are loaded from the root .env file via python-dotenv.
# Copy .env.example to .env, fill in your values, and run the pipeline —
# DLT reads SOURCES__* and DESTINATION__* env vars automatically and they
# take precedence over any values in this file.
#
# This file is kept as a fallback reference. If you prefer TOML over .env,
# copy it to secrets.toml and fill in the values below.

[sources.sql_database.credentials]
drivername = "mssql+pyodbc"
host = "127.0.0.1"
port = 1433
database = "AdventureWorks2014"
username = "sa"
password = "your_password"

[sources.sql_database.credentials.query]
driver = "ODBC Driver 18 for SQL Server"
TrustServerCertificate = "yes"

[destination.mssql.credentials]
host = "127.0.0.1"
port = 1433
database = "aw-db"
username = "sa"
password = "your_password"
driver = "ODBC Driver 18 for SQL Server"

[destination.mssql.credentials.query]
TrustServerCertificate = "yes"
Encrypt = "no"
