# Copy this file to .env and fill in your values.
# .env is git-ignored and will never be committed.

# ── DLT Source: AdventureWorks2014 ──────────────────────────────────────────
SOURCES__SQL_DATABASE__CREDENTIALS__DRIVERNAME=mssql+pyodbc
SOURCES__SQL_DATABASE__CREDENTIALS__HOST=127.0.0.1
SOURCES__SQL_DATABASE__CREDENTIALS__PORT=1433
SOURCES__SQL_DATABASE__CREDENTIALS__DATABASE=AdventureWorks2014
SOURCES__SQL_DATABASE__CREDENTIALS__USERNAME=sa
SOURCES__SQL_DATABASE__CREDENTIALS__PASSWORD=your_password
SOURCES__SQL_DATABASE__CREDENTIALS__QUERY__DRIVER=ODBC Driver 18 for SQL Server
SOURCES__SQL_DATABASE__CREDENTIALS__QUERY__TRUSTSERVERCERTIFICATE=yes

# ── DLT Destination: aw-db (staging) ────────────────────────────────────────
DESTINATION__MSSQL__CREDENTIALS__HOST=127.0.0.1
DESTINATION__MSSQL__CREDENTIALS__PORT=1433
DESTINATION__MSSQL__CREDENTIALS__DATABASE=aw-db
DESTINATION__MSSQL__CREDENTIALS__USERNAME=sa
DESTINATION__MSSQL__CREDENTIALS__PASSWORD=your_password
DESTINATION__MSSQL__CREDENTIALS__DRIVER=ODBC Driver 18 for SQL Server
DESTINATION__MSSQL__CREDENTIALS__QUERY__TRUSTSERVERCERTIFICATE=yes
DESTINATION__MSSQL__CREDENTIALS__QUERY__ENCRYPT=no

# ── dbt: aw-olap (data warehouse) ───────────────────────────────────────────
DBT_SERVER=127.0.0.1
DBT_PORT=1433
DBT_DATABASE=aw-olap
DBT_USER=sa
DBT_PASSWORD=your_password
DBT_DRIVER=ODBC Driver 18 for SQL Server
DBT_SCHEMA=main
DBT_THREADS=4

# ── Exchange rates ───────────────────────────────────────────────────────────
EXCHANGE_CURRENCY=USD
EXCHANGE_START_DATE=2011-01-01
EXCHANGE_END_DATE=2014-07-01
